<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/story_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="54dp"
    android:background="#F4F8FC"
    android:gravity="center_horizontal"
    android:layoutDirection="rtl">

    <LinearLayout
        android:id="@+id/story_header"
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp"
        android:background="#2F91F1">

        <TextView
            android:id="@+id/story_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="@font/cairo_bold" />

        <TextView
            android:id="@+id/story_week"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textColor="#EAF4FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/cairo_bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/story_shift_header"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical|right"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <TextView
            android:id="@+id/story_shift_icon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:gravity="center"
            android:textSize="42sp" />

        <TextView
            android:id="@+id/story_shift_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="right"
            android:textColor="#071F3A"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/cairo_bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/story_company_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="24dp" />
    </ScrollView>

    <TextView
        android:id="@+id/story_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="صيدلية برج الأطباء - إدارة الصيدلية"
        android:textColor="#607D9B"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/cairo_bold" />
</LinearLayout>
